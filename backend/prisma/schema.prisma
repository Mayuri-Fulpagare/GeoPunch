generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String
  name          String
  role          Role         @default(EMPLOYEE)
  deviceId      String?      // Used to bind user to a specific device
  attendances   Attendance[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model OfficeLocation {
  id          String   @id @default(uuid())
  name        String
  latitude    Float
  longitude   Float
  radius      Float    // Allowed radius in meters (e.g., 200m)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  checkInTime     DateTime
  checkOutTime    DateTime?
  checkInLat      Float
  checkInLon      Float
  checkOutLat     Float?
  checkOutLon     Float?
  status          Status    @default(PRESENT)
  accuracy        Float     // Accuracy in meters from GPS
  workingHours    Float?    // Total calculated working hours for the day
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum Role {
  EMPLOYEE
  ADMIN
}

enum Status {
  PRESENT
  LATE
  ABSENT
}
